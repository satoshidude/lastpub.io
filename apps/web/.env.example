# Build-time defaults for a fresh visitor. Copy to .env and adjust, or leave
# the file out entirely to keep the local dev-stack defaults.
#
# Values are baked into the bundle at build time, so a rebuild is needed after
# changing them. Anything a user saves in the settings panel takes precedence.

# Comma-separated relay URLs the app talks to.
VITE_DEFAULT_RELAYS=ws://127.0.0.1:7777

# npub of the scheduler ("tower") that accepts kind 5905 jobs and check-ins.
# Leave empty to force each visitor to enter one. There is no public default:
# a tower is an operated service, and pointing users at one they do not trust
# would defeat the point — it is the party that withholds and broadcasts the
# capsule. Run your own with `npm run dev-stack`, which prints its npub.
VITE_DEFAULT_TOWER_NPUB=
